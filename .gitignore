# ===== Companionship ChatBot .gitignore =====

# ---------- Environment / Secrets ----------
.env
.env.local
.env.*.local
# Keep .env.example files (they have no secrets)
!.env.example
!**/.env.example

# ---------- Python ----------
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.venv/
venv/
*.egg

# ---------- Go ----------
# Compiled binary (backend/api)
backend/api
*.exe
*.out

# ---------- Node / Frontend ----------
node_modules/
/.next/
/out/
.pnp
.pnp.js

# ---------- IDE / Editor ----------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------- OS ----------
.DS_Store
Thumbs.db
*.pem

# ---------- Docker ----------
docker-compose.override.yml

# ---------- Postman (local state) ----------
.postman/

# ---------- Markdown (only commit README.md) ----------
# Ignore all markdown except README.md
*.md
!README.md

# ---------- Misc ----------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
/coverage
*.tsbuildinfo
next-env.d.ts
.vercel
dashboard.txt

# ---------- WhatsApp Bot (local session) ----------
whatsapp_bot/auth/